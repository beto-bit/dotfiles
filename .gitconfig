[user]
	name = beto-bit
	email = 76757367+beto-bit@users.noreply.github.com

[includeIf "hasconfig:remote.*.url:git@github.uni:Alberto-V-USAC/**"]
	path = ~/gitcfg/.gitconfig-uni

[includeIf "gitdir:~/projects/uni/"]
	path = ~/gitcfg/.gitconfig-uni

[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process

[credential]
	helper = cache --timeout=2592000

[alias]
	st = status
	co = checkout
	unstage = reset HEAD --
	last = log -1 HEAD
	undo = reset HEAD^
	ci = commit
	dog = log --decorate --oneline --graph --all

[init]
	defaultBranch = main

[core]
	editor = vim
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true

[merge]
	conflictstyle = zdiff3
